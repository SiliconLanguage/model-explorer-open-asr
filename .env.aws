# ── AWS g5.2xlarge Production Environment ─────────────────────────────────────
# Copy to .env and adjust before deploying.
#
# Instance: g5.2xlarge — 1× NVIDIA A10G (24 GB VRAM), 8 vCPU, 32 GB RAM
# ─────────────────────────────────────────────────────────────────────────────

# Hugging Face token (required for gated models: Cohere, Granite Speech)
HF_TOKEN=

# Inference engine: faster_whisper | hf | vllm
# faster_whisper is recommended for production (CTranslate2, lowest latency)
# vllm works on A10G but has higher cold-start; use for multimodal models
ASR_ENGINE=faster_whisper

# GPU memory fraction for vLLM scheduler (only used when ASR_ENGINE=vllm)
# A10G has 24 GB — 0.85 leaves headroom for PyTorch CUDA context
GPU_MEMORY_UTILIZATION=0.85

# vLLM tuning
OPENASR_VLLM_MAX_MODEL_LEN=8192
OPENASR_VLLM_ENFORCE_EAGER=true
OPENASR_ENGINE_INIT_TIMEOUT_S=180

# Disable mock fallback in production
ALLOW_MOCK_FALLBACK=false

# CORS origin (tighten to your domain in production)
CORS_ALLOWED_ORIGIN=*
