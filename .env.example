# --- Security & Auth ---
# Required for gated models (Cohere, Granite, etc.)
HF_TOKEN=your_huggingface_token_here

# --- Performance & Infrastructure ---
# Reserved memory for vLLM KV cache (0.85 - 0.90 recommended)
GPU_MEMORY_UTILIZATION=0.88

# vLLM init timeout in seconds; lower values fail fast when the model cannot boot.
OPENASR_ENGINE_INIT_TIMEOUT_S=120

# Maximum model context length used for vLLM engine creation.
OPENASR_VLLM_MAX_MODEL_LEN=8192

# Use eager mode to avoid torch.compile instability on some WSL/GPU setups.
OPENASR_VLLM_ENFORCE_EAGER=true

# Keep false to avoid masking real backend failures with mock transcripts.
ALLOW_MOCK_FALLBACK=false

# Backend port (matches docker-compose and nginx proxy)
PORT=8000

# --- Frontend Context ---
# Vite/React configuration
VITE_API_BASE_URL=http://localhost:8000